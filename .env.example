# ─── Apollo.io ────────────────────────────────────────────────
APOLLO_API_KEY=your_apollo_api_key_here

# ─── Google Custom Search (for LinkedIn profile discovery) ────
GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# ─── OpenAI (for email generation) ───────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Google Sheets ────────────────────────────────────────────
SPREADSHEET_ID=your_google_sheet_id_here

# ─── Gmail Accounts (Priority Order) ─────────────────────────
GMAIL_1=your_first_gmail@gmail.com
GMAIL_2=your_second_gmail@gmail.com
GMAIL_3=your_third_gmail@gmail.com
GMAIL_4=your_fourth_gmail@gmail.com
