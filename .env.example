ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx # Claude Haiku + Sonnet — get from console.anthropic.com
SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxx   # SerpAPI (Scout B) — get from serpapi.com (free: 100/month)

# Google Sheets
